// ── RENDER ─────────────────────────────────────────────────────────────
function buildList(containerId, sections, progId, lblId) {
  const wrap = document.getElementById(containerId);
  let total = 0, done = 0;
  let html = '';
  sections.forEach(sec => {
    html += `<div class="sec-title">${sec.sec}</div>`;
    sec.items.forEach(it => {
      const isDone = saved[it.id] === true;
      const isPre = it.pre && !saved.hasOwnProperty(it.id);
      const cls = isDone ? 'done' : (isPre ? 'pre' : '');
      const badge = it.badge ? `<span class="badge ${it.badge}">${it.badge==='msg'?'mensagem':it.badge}</span>` : '';
      const note = it.note ? `<span class="note">${it.note}</span>` : '';
      html += `<div class="item ${cls}" onclick="toggle('${it.id}',this)" data-pre="${it.pre?'1':'0'}">
        <div class="chk"></div>
        <div class="itxt">${it.t}${badge}${note}</div>
      </div>`;
      total++;
      if (isDone || isPre) done++;
    });
  });
  wrap.innerHTML = html;
  const pct = total ? Math.round(done/total*100) : 0;
  document.getElementById(progId).style.width = pct + '%';
  document.getElementById(lblId).textContent = `${done} de ${total} concluídos (${pct}%)`;
}

function toggle(id, el) {
  const isPre = el.dataset.pre === '1' && !saved.hasOwnProperty(id);
  if (isPre) {
    // pre-done: primeiro clique desmarca
    saved[id] = false;
    el.classList.remove('pre');
  } else {
    saved[id] = !saved[id];
    el.classList.toggle('done', saved[id]);
  }
  persist();
  rebuildAll();
}

function persist() {
  try { localStorage.setItem(SK, JSON.stringify(saved)); } catch(e) {}
}

function rebuildAll() {
  buildList('l-geral',   lists.geral,   'pg-geral',   'pl-geral');
  buildList('l-umbanda', lists.umbanda, 'pg-umbanda', 'pl-umbanda');
  buildList('l-vespera', lists.vespera, 'pg-vespera', 'pl-vespera');
}

// DATAS
function buildDates() {
